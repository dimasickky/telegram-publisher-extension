{
  "manifest_schema_version": 3,
  "sdk_version": "5.9.12",
  "app_id": "telegram-publisher-extension",
  "version": "0.4.0",
  "name": "Telegram Publisher",
  "description": "Publish posts to your Telegram channels and read new posts for context — connect via one shared bot.",
  "icon": "icon.svg",
  "actions_explicit": true,
  "system": false,
  "capabilities": [
    "telegram-publisher-extension:read",
    "telegram-publisher-extension:write"
