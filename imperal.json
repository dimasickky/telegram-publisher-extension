  "tools": [
    {
      "name": "skeleton_refresh_channels_overview",
      "description": "Linked Telegram channels — id, title, can_post per channel.",
      "scopes": [],
      "parameters": {}
    },
    {
      "name": "skeleton_alert_channels_overview",
      "description": "Alert on channels linked or unlinked.",
      "scopes": [],
      "parameters": {
        "old": {
          "type": "string",
          "required": false
        },
        "new": {
          "type": "string",
          "required": false
        }
      }
    },
    {
      "name": "connect_telegram",
      "description": "Get a link to connect your Telegram account to this extension — open it in Telegram and tap Start. Needed once before you can link any channel.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "telegram.connect"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "label": {
            "default": "",
            "description": "Optional friendly label for this connection, e.g. if the user has already connected once and wants a second bot-link flow for a different set of channels. Omit for the default single link.",
            "title": "Label",
            "type": "string"
          }
        },
        "title": "ConnectTelegramParams",
        "type": "object"
      },
      "return_schema": {
        "properties": {
          "deep_link": {
            "description": "Open this in Telegram to link your account — taps Start automatically",
            "title": "Deep Link",
            "type": "string"
          }
        },
        "required": [
          "deep_link"
        ],
        "title": "ConnectTelegramResult",
        "type": "object"
      },
      "event": "telegram-publisher-extension.connect_telegram",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "telegram-publisher"
    },
